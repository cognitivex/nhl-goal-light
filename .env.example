# Local IP of the Hue Bridge. Set a DHCP reservation so this doesn't change.
HUE_BRIDGE_IP=192.168.1.50

# 40-char username from bridge pairing. See README for the curl flow.
HUE_API_USER=

# Light IDs from GET /api/{user}/lights
HUE_LIGHT_1=1
HUE_LIGHT_2=2

# Identifies you to the NHL API if they need to throttle abusive clients.
NHL_USER_AGENT=NhlGoalLight/1.0 (contact: you@example.com)
